# =============================================================================
# BEFIT GYM - ENVIRONMENT VARIABLES TEMPLATE
# =============================================================================
# Copy this file to .env and fill in your actual values
# Command: cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# AI CONFIGURATION (GEMINI)
# -----------------------------------------------------------------------------
# Your Google Gemini API key (get it from https://ai.google.dev/)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model identifier (use models/gemini-2.5-flash for best performance)
GEMINI_MODEL=models/gemini-2.5-flash

# Temperature controls response randomness (0.0=deterministic, 1.0=creative)
GEMINI_TEMPERATURE=0.2

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION (POSTGRESQL)
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=befit_gym_db
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgres://postgres:your_secure_password_here@db:5432/befit_gym_db

# -----------------------------------------------------------------------------
# DJANGO CONFIGURATION
# -----------------------------------------------------------------------------
DEBUG=True
SECRET_KEY=your_secret_key_here
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# -----------------------------------------------------------------------------
# CORS CONFIGURATION
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=True

# -----------------------------------------------------------------------------
# INTERNATIONALIZATION
# -----------------------------------------------------------------------------
LANGUAGE_CODE=en-us
TIME_ZONE=UTC

# -----------------------------------------------------------------------------
# JWT AUTHENTICATION
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# -----------------------------------------------------------------------------
# OPTIONAL: DEVELOPMENT TOOLS
# -----------------------------------------------------------------------------
# LOG_LEVEL=INFO
# SQL_DEBUG=False
